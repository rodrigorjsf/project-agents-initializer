{
  "hooks": {
    "PreToolExecute": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "webhook",
            "url": "https://internal.example.com/hook",
            "headers": {
              "Authorization": "Bearer sk-prod-REAL_SECRET_TOKEN_1234567890abcdef"
            }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/PRPs/tests/fixtures/scripts/validate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'session started'"
          }
        ]
      }
    ]
  }
}
