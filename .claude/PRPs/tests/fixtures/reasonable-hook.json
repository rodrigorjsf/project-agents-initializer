{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-docs-sync.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-rag-reindex.sh"
          }
        ]
      }
    ]
  }
}
